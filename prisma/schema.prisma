generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password_hash String?
  role          Role          @default(USER)
  created_at    DateTime      @default(now())
  steam_id      Int?          @unique
  settings      Json?
  game_times    GameTime[]    @relation("UserGameTimes")
  movie_reviews MovieReview[] @relation("UserMovieReviews")
  oauth         OAuth[]       @relation("UserOauth")
  wishlists     Wishlist[]    @relation("UserWishlists")
  trips         Trip[]        @relation("UserTrips")
  templates     Template[]    @relation("UserTemplates")
  gear_items       GearItem[]             @relation("UserGearItems")
  travel_wishlist  TravelWishlistItem[]   @relation("UserTravelWishlist")
  loadouts         Loadout[]              @relation("UserLoadouts")
}

model Game {
  id         Int        @id @default(autoincrement())
  appid      Int        @unique
  name       String
  game_times GameTime[] @relation("GameGameTimes")
}

model GameTime {
  id         Int      @id @default(autoincrement())
  user       String
  game       Int
  play_time  Int
  updated_at DateTime @default(now())
  game_rel   Game     @relation("GameGameTimes", fields: [game], references: [id])
  user_rel   User     @relation("UserGameTimes", fields: [user], references: [id])

  @@unique([user, game], name: "user_game")
}

model Movie {
  id            Int           @id @default(autoincrement())
  tmdb_id       Int           @unique
  name          String
  movie_reviews MovieReview[] @relation("MovieMovieReviews")
}

model MovieReview {
  id        Int    @id @default(autoincrement())
  user      String
  movie     Int
  rating    Int
  movie_rel Movie  @relation("MovieMovieReviews", fields: [movie], references: [id])
  user_rel  User   @relation("UserMovieReviews", fields: [user], references: [id])

  @@unique([user, movie], name: "user_movie")
}

model OAuth {
  id               Int    @id @default(autoincrement())
  provider         String
  provider_user_id String
  access_token     String
  user             String
  user_rel         User   @relation("UserOauth", fields: [user], references: [id])

  @@unique([user, provider], name: "user_provider")
}

model Band {
  id              Int                     @id @default(autoincrement())
  name            String                  @unique
  ticketmaster_id String?                 @unique
  created_at      DateTime?
  MBID            String?                 @unique
  songkick_url      String?
  bandsintown_url   String?
  setlist            Json?
  setlist_updated_at DateTime?
  concerts        ConcertBandReference[]  @relation("BandConcerts")
  wishlists       WishlistBandReference[] @relation("BandWishlists")
}

model Concert {
  id                Int                    @id @default(autoincrement())
  country           String
  venue             String
  created_at        DateTime
  on_sale           Boolean
  city              String
  concert_date      DateTime?
  event_id          String?                @unique
  latitude          String?                @db.VarChar
  longitude         String?                @db.VarChar
  metadata          String?
  name              String?
  ticket_sale_start DateTime?              @db.Timestamp(6)
  url               String?
  festival          Boolean?               @default(false)
  source            String?
  weather           Json?
  price_min         Float?
  price_max         Float?
  price_currency    String?
  sold_out          Boolean?               @default(false)
  reachable         String?
  city_id           Int?
  city_rel          City?                  @relation(fields: [city_id], references: [id])
  bands             ConcertBandReference[] @relation("ConcertBands")
  attendances       ConcertAttendance[]    @relation("ConcertAttendances")

  @@index([concert_date])
  @@index([concert_date, latitude, longitude])
}

model City {
  id                 Int       @id @default(autoincrement())
  name               String
  country            String
  latitude           Float?
  longitude          Float?
  reachable          String?
  airport_iata       String?
  weather_monthly    Json?
  weather_updated_at DateTime?
  created_at         DateTime  @default(now())
  concerts           Concert[]

  @@unique([name, country])
}

model Country {
  id   Int    @id @default(autoincrement())
  name String
  iso  String
}

model ConcertBandReference {
  id          Int     @id @default(autoincrement())
  concert     Int
  band        Int
  setlist     Json?
  band_rel    Band    @relation("BandConcerts", fields: [band], references: [id])
  concert_rel Concert @relation("ConcertBands", fields: [concert], references: [id])

  @@unique([concert, band], name: "concert_band")
}

model Wishlist {
  id                   Int                     @id @default(autoincrement())
  name                 String
  user_id              String                  @unique
  discord_webhook      String?
  concert_scores       String?
  city_rankings        String?
  scores_computed_at   DateTime?
  last_active_at       DateTime?
  user_rel             User                    @relation("UserWishlists", fields: [user_id], references: [id])
  bands                WishlistBandReference[] @relation("WishlistBands")
  activity_logs        ActivityLog[]           @relation("WishlistActivityLogs")
  attendance           ConcertAttendance[]     @relation("WishlistAttendance")
}

model ActivityLog {
  id           Int      @id @default(autoincrement())
  wishlist_id  Int
  type         String   // 'BAND_ADDED' | 'NEW_CONCERTS'
  data         String   // JSON
  created_at   DateTime @default(now())
  wishlist_rel Wishlist @relation("WishlistActivityLogs", fields: [wishlist_id], references: [id])
}

model WishlistBandReference {
  id           Int      @id @default(autoincrement())
  band_id      Int
  wishlist_id  Int
  tier         BandTier @default(FOLLOW)
  band_rel     Band     @relation("BandWishlists", fields: [band_id], references: [id])
  wishlist_rel Wishlist @relation("WishlistBands", fields: [wishlist_id], references: [id])

  @@unique([band_id, wishlist_id], name: "band_wishlist")
}

model ConcertAttendance {
  id           Int      @id @default(autoincrement())
  wishlist_id  Int
  concert_id   Int
  created_at   DateTime @default(now())
  wishlist_rel Wishlist @relation("WishlistAttendance", fields: [wishlist_id], references: [id])
  concert_rel  Concert  @relation("ConcertAttendances", fields: [concert_id], references: [id])

  @@unique([wishlist_id, concert_id])
}

enum Role {
  USER
  ADMIN
  SYSTEM
}

enum BandTier {
  LOVE
  LIKE
  FOLLOW
}

// ── TRAVEL BAG ────────────────────────────────────────────────────────────────

model Trip {
  id             Int               @id @default(autoincrement())
  user_id        String
  name           String            @db.VarChar(200)
  destination    String?           @db.VarChar(200)
  start_date     DateTime?         @db.Date
  end_date       DateTime?         @db.Date
  notes          String?           @db.Text
  weight_budget  Int?
  money_budget           Decimal?  @db.Decimal(10, 2)
  currency               String    @default("SEK") @db.VarChar(3)
  budget_flights         Decimal?  @db.Decimal(10, 2)
  budget_hotel           Decimal?  @db.Decimal(10, 2)
  budget_entertainment   Decimal?  @db.Decimal(10, 2)
  budget_food            Decimal?  @db.Decimal(10, 2)
  weather_data           Json?
  weather_updated_at     DateTime?
  created_at             DateTime  @default(now())
  updated_at     DateTime          @updatedAt
  user_rel       User              @relation("UserTrips", fields: [user_id], references: [id])
  items          TripItem[]
  estimates      ExpenseEstimate[]
}

model TripItem {
  id            Int           @id @default(autoincrement())
  trip_id       Int
  name          String        @db.VarChar(200)
  category      String?       @db.VarChar(100)
  status        PackingStatus @default(NEED_TO_BUY)
  note          String?       @db.Text
  url           String?       @db.VarChar(500)
  sort_order    Int           @default(0)
  gear_item_id  Int?
  worn          Boolean       @default(false)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  bag_id        Int?
  trip_rel      Trip          @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  gear_item_rel GearItem?     @relation("GearItemTripItems", fields: [gear_item_id], references: [id], onDelete: SetNull)
  bag_rel       GearItem?     @relation("TripItemBag", fields: [bag_id], references: [id], onDelete: SetNull)
}

model ExpenseEstimate {
  id         Int      @id @default(autoincrement())
  trip_id    Int
  category   String   @db.VarChar(100)
  amount     Decimal  @db.Decimal(10, 2)
  currency   String    @default("SEK") @db.VarChar(3)
  date       DateTime? @db.Date
  end_date   DateTime? @db.Date
  note       String?   @db.Text
  sort_order Int       @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  trip_rel   Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

model Template {
  id          Int            @id @default(autoincrement())
  user_id     String
  name        String         @db.VarChar(200)
  description String?        @db.Text
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  user_rel    User           @relation("UserTemplates", fields: [user_id], references: [id])
  items       TemplateItem[]
}

model TemplateItem {
  id           Int      @id @default(autoincrement())
  template_id  Int
  name         String   @db.VarChar(200)
  category     String?  @db.VarChar(100)
  note         String?  @db.Text
  url          String?  @db.VarChar(500)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())
  template_rel Template @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model GearItem {
  id         Int        @id @default(autoincrement())
  user_id    String
  name       String     @db.VarChar(200)
  model      String?    @db.VarChar(200)
  brand      String?    @db.VarChar(100)
  category   String?    @db.VarChar(100)
  dimensions Json?
  tags       String[]
  sort_order Int      @default(0)
  worn       Boolean  @default(false)
  notes      String?    @db.Text
  url        String?    @db.VarChar(500)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  user_rel        User           @relation("UserGearItems", fields: [user_id], references: [id])
  trip_items      TripItem[]     @relation("GearItemTripItems")
  trip_bag_items  TripItem[]     @relation("TripItemBag")
  loadout_entries LoadoutEntry[] @relation("GearItemLoadoutEntries")
  bag_entries     LoadoutEntry[] @relation("LoadoutEntryBag")
}

model TravelWishlistItem {
  id         Int      @id @default(autoincrement())
  user_id    String
  name       String   @db.VarChar(200)
  brand      String?  @db.VarChar(100)
  model      String?  @db.VarChar(200)
  category   String?  @db.VarChar(100)
  url        String?  @db.VarChar(500)
  notes      String?  @db.Text
  price      Float?
  currency   String   @default("SEK") @db.VarChar(3)
  dimensions Json?
  keywords   String[]
  bought     Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user_rel   User     @relation("UserTravelWishlist", fields: [user_id], references: [id])
}

model Loadout {
  id             Int            @id @default(autoincrement())
  user_id        String
  name           String         @db.VarChar(200)
  description    String?        @db.Text
  weight_budget  Int?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  user_rel       User           @relation("UserLoadouts", fields: [user_id], references: [id])
  entries        LoadoutEntry[]
}

model LoadoutEntry {
  id            Int       @id @default(autoincrement())
  loadout_id    Int
  gear_item_id  Int
  worn          Boolean   @default(false)
  bag_id        Int?
  created_at    DateTime  @default(now())
  loadout_rel   Loadout   @relation(fields: [loadout_id], references: [id], onDelete: Cascade)
  gear_item_rel GearItem  @relation("GearItemLoadoutEntries", fields: [gear_item_id], references: [id], onDelete: Cascade)
  bag_rel       GearItem? @relation("LoadoutEntryBag", fields: [bag_id], references: [id], onDelete: SetNull)

  @@unique([loadout_id, gear_item_id])
}

enum PackingStatus {
  NEED_TO_BUY
  BOUGHT
  PACKED
  NOT_PACKED
}
